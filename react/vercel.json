{
  "version": 2,
  "buildCommand": "cd react && npm run build",
  "outputDirectory": "react/dist",
  "devCommand": "cd react && npm run dev",
  "installCommand": "cd react && npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
